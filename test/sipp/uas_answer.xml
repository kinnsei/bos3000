<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">
<!--
  BOS3000 SIPp UAS scenario - simulates a phone that answers calls.
  Usage: sipp -sf uas_answer.xml -p 6090 -m 10
-->
<scenario name="BOS3000 UAS - Answer and Hold">

  <!-- Wait for INVITE -->
  <recv request="INVITE" crlf="true"/>

  <!-- Send 100 Trying -->
  <send>
    <![CDATA[
      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <!-- Pause 500ms to simulate ringing delay -->
  <pause milliseconds="500"/>

  <!-- Send 180 Ringing -->
  <send>
    <![CDATA[
      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <!-- Pause 1s to simulate user picking up -->
  <pause milliseconds="1000"/>

  <!-- Send 200 OK with SDP -->
  <send retrans="500">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=sipp 1 1 IN IP[local_ip_type] [local_ip]
      s=SIPp UAS
      c=IN IP[local_ip_type] [local_ip]
      t=0 0
      m=audio [auto_media_port] RTP/AVP 0 8 101
      a=rtpmap:0 PCMU/8000
      a=rtpmap:8 PCMA/8000
      a=rtpmap:101 telephone-event/8000
      a=fmtp:101 0-15
      a=ptime:20

    ]]>
  </send>

  <!-- Wait for ACK -->
  <recv request="ACK" optional="false" rtd="true" crlf="true"/>

  <!-- Hold the call for 5 seconds (simulates conversation) -->
  <pause milliseconds="5000"/>

  <!-- Send BYE to end call -->
  <send retrans="500">
    <![CDATA[
      BYE [last_Request-URI:] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      CSeq: 2 BYE
      Max-Forwards: 70
      Content-Length: 0

    ]]>
  </send>

  <!-- Wait for 200 OK to BYE -->
  <recv response="200" crlf="true"/>

  <ResponseTimeRepartition value="100, 200, 500, 1000, 2000, 5000"/>
  <CallLengthRepartition value="1000, 5000, 10000, 30000"/>

</scenario>
