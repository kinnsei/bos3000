# BOS3000 Production Environment Configuration
# Copy to .env and fill in values before running install.sh
# Note: install.sh generates .env automatically — this file is for reference only.

# ---- Database ----
# PostgreSQL connection for all Encore services (auth, billing, callback, etc.)
BOS3000_DB_HOST=127.0.0.1
BOS3000_DB_PORT=5432
BOS3000_DB_USER=bos3000
BOS3000_DB_PASSWORD=<change-me>
BOS3000_DB_NAME=auth

# ---- Redis ----
# Used for caching (call state, rate limits, session data)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ---- FreeSWITCH ESL ----
# FS_MODE: "real" connects to a live FreeSWITCH instance via ESL
#          "mock" uses an in-memory stub (development/testing without FS)
FS_MODE=real
# ESL address — default FreeSWITCH listens on 8021
FS_ADDRESS=<fs-host>:8021
# ESL password — must match event_socket.conf.xml in FreeSWITCH
FS_PASSWORD=<change-me>

# ---- Secrets ----
# JWT signing key for admin/client auth tokens (min 32 chars recommended)
JWT_SECRET=<change-me-random-32-chars>

# ---- Network ----
# EIP: Elastic/public IP for SIP signaling (used in SDP and SIP Contact headers)
EIP=<your-elastic-ip>
SIP_EXTERNAL_IP=${EIP}

# ---- Ports (informational, not configurable via env) ----
# API_PORT=4000          # Encore HTTP API
# SIP_PORT=5060          # FreeSWITCH SIP (UDP+TCP)
# ESL_PORT=8021          # FreeSWITCH Event Socket
# RTP_RANGE=16384-32768  # RTP media ports (UDP)
