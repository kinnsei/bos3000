# BOS3000 Production Environment Configuration
# Copy to .env and fill in values before running install.sh

# ---- Database ----
BOS3000_DB_HOST=localhost
BOS3000_DB_PORT=5432
BOS3000_DB_USER=bos3000
BOS3000_DB_PASSWORD=<change-me>
BOS3000_DB_NAME=bos3000

# ---- FreeSWITCH ESL ----
FS_MODE=real
FS_ADDRESS=<fs-host>:8021
FS_PASSWORD=<change-me>

# ---- Secrets ----
JWT_SECRET=<change-me-random-32-chars>

# ---- Network ----
# EIP: Elastic IP for SIP signaling (public IP of this server)
EIP=<your-elastic-ip>
SIP_EXTERNAL_IP=${EIP}

# ---- Ports ----
# API_PORT=4000          # Encore default
# SIP_PORT=5060          # FreeSWITCH SIP
# ESL_PORT=8021          # FreeSWITCH ESL
